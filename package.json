{
  "name": "taskmatebot",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "dev": "MASTRA_IGNORE_PATTERNS=*.md mastra dev",
    "build": "npx mastra build",
    "build:ts": "npx tsc --project tsconfig.json",
    "build:ts:watch": "npx tsc --project tsconfig.json --watch",
    "dev:i": "npx tsx watch src/index.ts",
    "start": "npx tsx src/index.ts",
    "start:health": "npx tsx src/health.ts",
    "migrate": "npx tsx src/scripts/runMigration.ts",
    "start:cloudrun": "npx tsx src/health-cloudrun.ts",
    "start:combined": "npx tsx start-combined-bots.ts",
    "start:prod": "node --max-old-space-size=512 dist/index.js",
    "docker:build": "docker build -t taskmate-bot:latest .",
    "docker:run": "docker run -p 3000:3000 --env-file .env taskmate-bot:latest",
    "docker:compose:up": "docker-compose up -d",
    "docker:compose:down": "docker-compose down",
    "docker:compose:logs": "docker-compose logs -f taskmate-bot",
    "docker:compose:build": "docker-compose build",
    "k8s:deploy": "kubectl apply -f k8s/ -n taskmate",
    "k8s:status": "kubectl get pods,svc,hpa -n taskmate",
    "k8s:logs": "kubectl logs -f -n taskmate -l app=taskmate-bot",
    "k8s:delete": "kubectl delete -f k8s/ -n taskmate",
    "deploy": "./scripts/deploy.sh",
    "deploy:docker": "./scripts/deploy.sh -d docker-compose deploy",
    "deploy:k8s": "./scripts/deploy.sh -d kubernetes deploy",
    "deploy:test": "./scripts/deploy.sh test",
    "deploy:clean": "./scripts/deploy.sh clean",
    "deploy:gce": "./deploy-gce.sh",
    "gcp:setup": "gcloud services enable compute.googleapis.com cloudbuild.googleapis.com artifactregistry.googleapis.com",
    "gcp:build": "gcloud builds submit --tag gcr.io/$GOOGLE_CLOUD_PROJECT/taskmate-bot .",
    "gcp:deploy": "gcloud compute instances create-with-container taskmate-bot --container-image gcr.io/$GOOGLE_CLOUD_PROJECT/taskmate-bot:latest --zone us-central1-a --machine-type e2-small",
    "gcp:logs": "gcloud compute ssh taskmate-bot --zone=us-central1-a --command='docker logs -f taskmate-bot'",
    "gcp:ssh": "gcloud compute ssh taskmate-bot --zone=us-central1-a",
    "gcp:diagnose": "./diagnose-and-fix.sh",
    "gcp:update-env": "./update-env.sh",
    "gcp:restart": "gcloud compute ssh taskmate-bot --zone=us-central1-a --command='sudo docker restart taskmate-bot'",
    "gcp:status": "gcloud compute ssh taskmate-bot --zone=us-central1-a --command='sudo docker ps && sudo docker logs taskmate-bot --tail 20'"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "type": "module",
  "engines": {
    "node": ">=20.9.0"
  },
  "dependencies": {
    "@ai-sdk/google": "^1.2.19",
    "@ai-sdk/openai": "^1.3.22",
    "@hono/node-server": "^1.14.4",
    "@mastra/core": "0.10.5",
    "@mastra/libsql": "0.10.2",
    "@mastra/loggers": "^0.10.2",
    "@mastra/memory": "0.10.3",
    "@mastra/pg": "^0.10.3",
    "@microsoft/teams-js": "^2.39.0",
    "@slack/bolt": "^4.4.0",
    "@supabase/supabase-js": "^2.50.0",
    "@types/express": "^5.0.3",
    "@types/node-cron": "^3.0.11",
    "axios": "^1.9.0",
    "botbuilder": "^4.23.2",
    "botbuilder-teams": "^0.2.9",
    "date-fns": "^4.1.0",
    "dotenv": "^16.5.0",
    "express": "^5.1.0",
    "hono": "^4.7.11",
    "node-cron": "^4.1.0",
    "openai": "^5.3.0",
    "telegraf": "^4.16.3",
    "tsx": "^4.20.3",
    "zod": "^3.25.64"
  },
  "devDependencies": {
    "@types/node": "^24.0.1",
    "mastra": "^0.10.5",
    "typescript": "^5.8.3"
  },
  "packageManager": "pnpm@9.4.0+sha256.b6fd0bfda555e7e584ad7e56b30c68b01d5a04f9ee93989f4b93ca8473c49c74"
}
