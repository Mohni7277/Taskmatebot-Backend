# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
NEXT_PUBLIC_SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
SUPABASE_DB_URL=your_supabase_database_connection_string

# OpenAI Configuration
OPENAI_API_KEY=your_openai_api_key

# App Configuration
NEXT_PUBLIC_APP_URL=http://localhost:3000
BOT_BASE_URL=https://your-public-bot-domain.com

# Teams Bot Configuration
MICROSOFT_APP_ID=your_microsoft_app_id
MICROSOFT_APP_PASSWORD=your_microsoft_app_password
MICROSOFT_TENANT_ID=your_microsoft_tenant_id
TEAMS_PORT=3001

# ngrok Configuration
NGROK_URL=https://your-ngrok-url.ngrok.io

# WhatsApp Configuration
WAAPI_API_KEY=your_waapi_api_key
WAAPI_INSTANCE_ID=your_waapi_instance_id
WEBHOOK_PORT=3005
SECURITY_TOKEN=your_security_token

# Telegram Configuration
TELEGRAM_BOT_TOKEN=your_telegram_bot_token

# Slack Configuration
SLACK_APP_TOKEN=your_slack_app_token
SLACK_BOT_TOKEN=your_slack_bot_token

# Runtime Configuration
NODE_ENV=development
PORT=3000
HEALTH_CHECK_PORT=8080
LOG_LEVEL=info
