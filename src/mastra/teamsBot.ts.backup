        // Determine emoji based on status
        let statusEmoji = "📝";
        switch (newStatus) {
          case "in_progress": statusEmoji = "🚧"; break;
          case "completed": statusEmoji = "✅"; break;
          case "cancelled": statusEmoji = "❌"; break;
